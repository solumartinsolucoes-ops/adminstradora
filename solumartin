<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Solumartín Soluções Condominiais</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#0f1118;
    color:#fff;
}

/* TOPO */
header{
    background:linear-gradient(135deg,#0c0f17,#112b63,#0c0f17);
    padding:20px;
    text-align:center;
    position:sticky;
    top:0;
    z-index:999;
    box-shadow:0 4px 15px rgba(0,0,0,0.4);
}

header img{
    width:180px;
    max-width:90%;
    margin-bottom:10px;
}

header h1{
    font-size:38px;
    margin-bottom:5px;
}

header p{
    font-size:18px;
    color:#b9d7ff;
    margin-bottom:18px;
}

.top-buttons{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:12px;
}

.top-buttons a{
    background:#1d4ed8;
    color:#fff;
    padding:12px 22px;
    border-radius:40px;
    text-decoration:none;
    font-weight:bold;
    transition:0.3s;
}

.top-buttons a:hover{
    background:#2563eb;
    transform:translateY(-2px);
}

/* HERO */
.hero{
    padding:70px 20px;
    text-align:center;
    background:linear-gradient(to bottom,#10131d,#0f1118);
}

.hero h2{
    font-size:42px;
    margin-bottom:15px;
}

.hero span{
    color:#60a5fa;
}

.hero p{
    max-width:850px;
    margin:auto;
    font-size:20px;
    line-height:1.7;
    color:#ddd;
}

/* SERVIÇOS */
.section{
    padding:70px 20px;
    max-width:1300px;
    margin:auto;
}

.section h3{
    text-align:center;
    font-size:36px;
    margin-bottom:50px;
    color:#60a5fa;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.card{
    background:linear-gradient(180deg,#161a26,#0d1118);
    border:1px solid rgba(255,255,255,0.06);
    padding:28px;
    border-radius:18px;
    text-align:center;
    transition:0.3s;
}

.card:hover{
    transform:translateY(-6px);
    box-shadow:0 10px 25px rgba(0,0,0,0.35);
}

.card h4{
    font-size:23px;
    color:#fff;
    margin-bottom:15px;
}

.card p{
    line-height:1.7;
    color:#d8d8d8;
}

/* FUNCIONALIDADES APP */
.baloes{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:30px;
}

.balao{
    text-align:center;
}

.circulo{
    width:130px;
    height:130px;
    border-radius:50%;
    margin:auto;
    margin-bottom:15px;
    background:linear-gradient(135deg,#5b21b6,#16a34a);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
    font-weight:bold;
    padding:20px;
}

.balao h5{
    font-size:22px;
    margin-bottom:10px;
}

.balao p{
    line-height:1.7;
    color:#ddd;
}

/* DOWNLOAD */
.download{
    text-align:center;
}

.download p{
    margin-bottom:25px;
    font-size:20px;
}

.store-buttons{
    display:flex;
    justify-content:center;
    gap:15px;
    flex-wrap:wrap;
}

.store-buttons a{
    background:#111827;
    border:1px solid #2563eb;
    padding:15px 28px;
    border-radius:12px;
    color:#fff;
    text-decoration:none;
    font-weight:bold;
    transition:0.3s;
}

.store-buttons a:hover{
    background:#2563eb;
}

/* CONTATO */
footer{
    background:#090c13;
    text-align:center;
    padding:35px 20px;
    margin-top:50px;
}

footer p{
    margin:8px 0;
    color:#ddd;
}

/* BOTÕES FLUTUANTES */
.float{
    position:fixed;
    right:18px;
    z-index:999;
}

.whats{
    bottom:85px;
}

.insta{
    bottom:20px;
}

.float a{
    width:55px;
    height:55px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    text-decoration:none;
    color:#fff;
    font-size:26px;
    box-shadow:0 6px 15px rgba(0,0,0,0.35);
}

.whats a{
    background:#25D366;
}

.insta a{
    background:#E1306C;
}

@media(max-width:700px){

header h1{
    font-size:28px;
}

.hero h2{
    font-size:30px;
}

.section h3{
    font-size:28px;
}

}
</style>
</head>

